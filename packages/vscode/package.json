{
  "name": "topicmd-vscode",
  "displayName": "topicmd",
  "version": "0.1.0",
  "publisher": "topicmd",
  "license": "MIT",
  "description": "Topic Health panel, frontmatter intelligence, and Quick Scaffold for docs-as-code Markdown projects.",
  "categories": ["Other", "Linters"],
  "keywords": ["markdown", "documentation", "docs-as-code", "i18n", "topicmd"],
  "icon": "icon.png",
  "homepage": "https://motorradhexe.github.io/topicmd/",
  "repository": {
    "type": "git",
    "url": "https://github.com/motorradhexe/topicmd.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/motorradhexe/topicmd/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "topicmdHealth",
          "name": "Topic Health"
        }
      ]
    },
    "commands": [
      {
        "command": "topicmd.refreshHealth",
        "title": "topicmd: Refresh Topic Health"
      },
      {
        "command": "topicmd.scaffoldTopic",
        "title": "topicmd: New Topic…"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --minify --outfile=dist/extension.js",
    "build:dev": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --sourcemap --outfile=dist/extension.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@topicmd/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0"
  }
}
