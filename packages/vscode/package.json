{
  "name": "topicmd-vscode",
  "displayName": "topicmd",
  "version": "0.1.0",
  "publisher": "topicmd",
  "license": "MIT",
  "description": "Manage documentation topics in VS Code by meaning — type, dimensions, profiles, language — instead of by folder tree.",
  "categories": ["Other", "Linters"],
  "keywords": ["markdown", "documentation", "docs-as-code", "i18n", "topicmd"],
  "icon": "icon.png",
  "homepage": "https://motorradhexe.github.io/topicmd/",
  "repository": {
    "type": "git",
    "url": "https://github.com/motorradhexe/topicmd.git",
    "directory": "packages/vscode"
  },
  "bugs": {
    "url": "https://github.com/motorradhexe/topicmd/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "topicmd",
          "title": "topicmd",
          "icon": "media/topicmd.svg"
        }
      ]
    },
    "views": {
      "topicmd": [
        {
          "id": "topicmdTopics",
          "name": "Topics",
          "type": "webview"
        },
        {
          "id": "topicmdHealth",
          "name": "Topic Health"
        }
      ]
    },
    "commands": [
      {
        "command": "topicmd.newTopic",
        "title": "topicmd: New Topic…",
        "icon": "$(add)"
      },
      {
        "command": "topicmd.refreshTopics",
        "title": "topicmd: Refresh Topics",
        "icon": "$(refresh)"
      },
      {
        "command": "topicmd.refreshHealth",
        "title": "topicmd: Refresh Topic Health",
        "icon": "$(refresh)"
      },
      {
        "command": "topicmd.scaffoldTopic",
        "title": "topicmd: Scaffold Topic (preview in editor)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "topicmd.newTopic",
          "when": "view == topicmdTopics",
          "group": "navigation"
        },
        {
          "command": "topicmd.refreshTopics",
          "when": "view == topicmdTopics",
          "group": "navigation"
        },
        {
          "command": "topicmd.refreshHealth",
          "when": "view == topicmdHealth",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:dev": "node esbuild.mjs --dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@topicmd/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0"
  }
}
